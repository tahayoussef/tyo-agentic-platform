# Copy to `.env` and fill in real values. `.env` is git-ignored — never commit secrets.

# --- NVIDIA AI endpoints (required) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The reasoning model used by the specialists and the supervisor.
NVIDIA_CHAT_MODEL=z-ai/glm-5.2
# Optional smaller/cheaper model for the routing decision only (falls back to the chat model).
# Routing is a classification task — it doesn't need the big model.
# NVIDIA_ROUTER_MODEL=meta/llama-3.1-8b-instruct

# --- Orchestration ---
# router:     classify the query, dispatch to exactly ONE specialist (cheap, single hop).
# supervisor: an LLM coordinator that can consult SEVERAL specialists and synthesize.
ORCHESTRATION_MODE=router

# --- Docs specialist (local markdown knowledge base) ---
KNOWLEDGE_BASE_DIR=knowledge_base
DOCS_TOP_K=3

# --- GitHub specialist (live source) ---
GITHUB_USERNAME=your-github-handle
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# --- Observability ---
LOG_LEVEL=INFO
LOG_JSON=false
