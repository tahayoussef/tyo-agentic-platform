# Copy to `.env` and fill in real values. `.env` is git-ignored — never commit secrets.

# --- NVIDIA AI endpoints (required) ---
# Get a key at https://build.nvidia.com/. Rotate immediately if it ever leaks.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=z-ai/glm-5.2
LLM_TEMPERATURE=1.0
LLM_TOP_P=1.0
LLM_MAX_TOKENS=16384
LLM_SEED=42

# --- GitHub ---
# Default account the agent inspects when no username is given in the question.
GITHUB_USERNAME=your-github-handle
# Optional: a Personal Access Token (public_repo scope is enough) raises the
# unauthenticated rate limit from 60 to 5000 requests/hour.
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_API_BASE_URL=https://api.github.com
REQUEST_TIMEOUT_SECONDS=30

# --- Observability ---
LOG_LEVEL=INFO
# Set to true for machine-readable JSON logs (recommended in production).
LOG_JSON=false
