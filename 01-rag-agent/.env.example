# Copy to `.env` and fill in real values. `.env` is git-ignored — never commit secrets.

# --- NVIDIA AI endpoints (required for embeddings) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
# How to handle inputs longer than the model's context: NONE | START | END
EMBEDDING_TRUNCATE=END

# --- Qdrant (the vector DB, hosted via docker-compose) ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=            # only needed for secured / cloud Qdrant
COLLECTION_NAME=github_repos

# --- Ingestion ---
KNOWLEDGE_BASE_DIR=github_repos_readmes
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval ---
TOP_K=4
# Retrieval mode: dense (semantic only) or hybrid (semantic + BM25 keyword)
RETRIEVAL_MODE=dense
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# --- Reranking (two-stage: fetch many, then re-score with a cross-encoder) ---
USE_RERANKER=false
RERANKER_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2
RERANK_FETCH_K=20

# --- GitHub (live source — used by the agent in a later phase) ---
GITHUB_USERNAME=your-github-handle
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# --- Observability ---
LOG_LEVEL=INFO
LOG_JSON=false
